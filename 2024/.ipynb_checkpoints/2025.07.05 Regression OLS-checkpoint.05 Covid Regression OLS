    "# Flatten the correlation matrix and remove self-correlations\n",
    "correlation_pairs = correlation_matrix.unstack().reset_index()\n",
    "correlation_pairs.columns = [\"Variable 1\", \"Variable 2\", \"Correlation\"]\n",
