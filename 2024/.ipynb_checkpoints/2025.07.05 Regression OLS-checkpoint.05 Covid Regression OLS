    "X_train, X_test, y_train, y_test = train_test_split(X_rf, y_rf, test_size=0.3, random_state=42)\n",
    "\n",
    "# 3. Fit Random Forest\n",
    "rf = RandomForestRegressor(n_estimators=100, random_state=42)\n",
