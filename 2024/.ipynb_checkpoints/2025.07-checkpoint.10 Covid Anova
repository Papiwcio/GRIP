    "# STEP 1: Filter for 2023 only (already done earlier, included here for completeness)\n",
    "df_2023 = df[df['Year'] == 2023].copy()\n",
    "\n",
    "# STEP 2: Select and clean required columns (drop missing values)\n",
    "df_2023_partial = df_2023[['SGrowth_2023_2019', 'RSGrowth_2023_2019', 'HGX', 'HGX%', 'P/F', 'Sales']].dropna().copy()\n",
    "\n",
    "# STEP 3: Create strategic group labels (Ownership + Export trend)\n",
    "df_2023_partial['Group'] = df_2023_partial['P/F'] + \" - \" + df_2023_partial['HGX'].str.replace(\"Export Intensity\", \"Export\")\n",
    "\n",
    "# STEP 4: Compute unweighted descriptive statistics (firm-level view)\n",
    "summary = df_2023_partial.groupby('Group').agg(\n",
    "    Number_of_Companies=('SGrowth_2023_2019', 'count'),\n",
    "    Average_Sales_Growth=('SGrowth_2023_2019', 'mean'),\n",
    "    Average_Real_Sales_Growth=('RSGrowth_2023_2019', 'mean'),\n",
    "    Average_HGX_Percent=('HGX%', 'mean')\n",
    ").round(2)\n",
    "\n",
    "# STEP 5: Format group names for clarity\n",
    "summary.index = summary.index.str.replace('Export Intensity', 'Export', regex=False)\n",
    "\n",
    "# STEP 6: Sort groups logically for presentation\n",
    "group_order = [\n",
    "    'P - Increased Export', 'P - Decreased Export',\n",
    "    'F - Increased Export', 'F - Decreased Export'\n",
    "]\n",
    "summary = summary.loc[group_order]\n",
