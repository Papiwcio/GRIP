    "# STEP 6: Write to Excel using xlsxwriter (including charts)\n",
    "excel_path = \"growth_analysis_with_charts.xlsx\"\n",
    "with pd.ExcelWriter(excel_path, engine='xlsxwriter') as writer:\n",
    "    summary_table.to_excel(writer, sheet_name='Descriptive Summary')\n",
    "    anova_table.to_excel(writer, sheet_name='ANOVA Result', index=False)\n",
    "\n",
    "    workbook  = writer.book\n",
    "    worksheet = workbook.add_worksheet('Charts')\n",
    "    writer.sheets['Charts'] = worksheet\n",
    "\n",
